TZ=Europe/Paris

# 0 = image legere (sans transformers/torch/praw/google-genai)
# 1 = installe aussi les dependances IA optionnelles
INSTALL_AI_DEPS=0
BUBO_WEB_PORT=7654
BUBO_WEB_AUTH_ENABLED=1
BUBO_WEB_USER=admin
BUBO_WEB_PASSWORD=change-me
BUBO_WEB_SECRET=change-this-secret

# Config par defaut de l'UI web
BUBO_UNIVERSE_FILE=data/universe_global_v1.txt
BUBO_PRESELECT_TOP=60
BUBO_MAX_DEEP=20
BUBO_CAPITAL=10000
BUBO_PAPER_ENABLED=1
BUBO_PAPER_STATE=data/paper_portfolio_state.json
BUBO_NO_FINBERT=1
BUBO_NO_BUDGET_GATE=0

# Optionnel (utilise par bubo_brain.py si tu lances ce script)
GEMINI_API_KEY=

# Optionnel: webhook Discord/Slack pour alertes paper
BUBO_PAPER_WEBHOOK=

# APIs optionnelles (news + social)
BUBO_NEWSAPI_KEY=
BUBO_FINNHUB_KEY=
BUBO_REDDIT_CLIENT_ID=
BUBO_REDDIT_CLIENT_SECRET=
BUBO_REDDIT_USER_AGENT=Bubo/1.0 by u/YOUR_REDDIT_USERNAME

# Utilise par docker-compose.ghcr.yml
BUBO_IMAGE=ghcr.io/your-github-user/bubo-trading:latest

TZ=Europe/Paris

# 0 = image legere (sans transformers/torch/praw)
# 1 = installe aussi les dependances IA optionnelles (FinBERT + social Reddit)
INSTALL_AI_DEPS=0
BUBO_WEB_PORT=7654
BUBO_CONNECTIVITY_CACHE_TTL_S=120
BUBO_BROKER_SNAPSHOT_CACHE_TTL_S=60
BUBO_WEB_AUTH_ENABLED=1
BUBO_WEB_USER=admin
BUBO_WEB_PASSWORD=change-me
BUBO_WEB_SECRET=change-this-secret

# Config par defaut de l'UI web
BUBO_DECISION_ENGINE=llm
BUBO_UNIVERSE_FILE=data/universe_global_v1.txt
BUBO_PRESELECT_TOP=60
BUBO_MAX_DEEP=8
BUBO_WATCH_INTERVAL_MIN=30
BUBO_CAPITAL=10000
BUBO_PAPER_ENABLED=1
BUBO_PAPER_STATE=data/paper_portfolio_state.json
BUBO_PAPER_BROKER=ibkr
BUBO_IBKR_HOST=ib-gateway
BUBO_IBKR_PORT=4004
BUBO_IBKR_CLIENT_ID=42
BUBO_IBKR_ACCOUNT=
BUBO_IBKR_EXCHANGE=SMART
BUBO_IBKR_CURRENCY=USD
BUBO_IBKR_CAPITAL_LIMIT=10000
BUBO_IBKR_EXISTING_POSITIONS_POLICY=include
BUBO_NO_FINBERT=1
BUBO_NO_BUDGET_GATE=0

# Optionnel (utilise par bubo_brain.py si tu lances ce script)
GEMINI_API_KEY=

# Optionnel: webhook Discord/Slack pour alertes paper
BUBO_PAPER_WEBHOOK=

# APIs optionnelles (news + social)
BUBO_NEWSAPI_KEY=
BUBO_FINNHUB_KEY=
BUBO_REDDIT_CLIENT_ID=
BUBO_REDDIT_CLIENT_SECRET=
BUBO_REDDIT_USER_AGENT=Bubo/1.0 by u/YOUR_REDDIT_USERNAME
BUBO_STOCKTWITS_BASE_URL=https://api.stocktwits.com/api/2
BUBO_STOCKTWITS_TEST_SYMBOL=AAPL

# Utilise par docker-compose.ghcr.yml
BUBO_IMAGE=ghcr.io/your-github-user/bubo-trading:latest

# Optionnel: service ib-gateway (profile "ibkr")
IBG_TWS_USERID=
IBG_TWS_PASSWORD=
IBG_TRADING_MODE=paper
IBG_READ_ONLY_API=no
IBG_TWS_ACCEPT_INCOMING=accept
IBG_TWOFA_TIMEOUT_ACTION=restart
IBG_VNC_SERVER_PASSWORD=
IBG_JAVA_HEAP_SIZE=
IBG_HOST_PAPER_PORT=4002
IBG_HOST_LIVE_PORT=4001
IBG_HOST_VNC_PORT=5900
